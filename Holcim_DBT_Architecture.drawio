        <mxCell id="gold" value="models/gold&#10;&#10;fact_sales&#10;fact_inventory&#10;fact_shipments&#10;&#10;dim_customer&#10;dim_product&#10;dim_region&#10;&#10;kpi_sales&#10;kpi_logistics" style="swimlane;html=1;" vertex="1" parent="project">
