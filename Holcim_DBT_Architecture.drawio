        <mxCell id="caps" value="DBT Capabilities&#10;&#10;Incremental Models&#10;Snapshots&#10;Lineage&#10;Documentation&#10;Data Quality" style="swimlane;html=1;" vertex="1" parent="project">
          <mxGeometry x="860" y="40" width="120" height="420" as="geometry"/>
        </mxCell>

        <mxCell id="tests" value="dbt tests" style="rounded=1;html=1;" vertex="1" parent="dbtlayer">
